# ============================================
# Configuration pour le Déploiement Gratuit
# ============================================

# Base de Données (TiDB Cloud ou Supabase)
# Exemple TiDB : mysql://user:password@host:3306/database
# Exemple Supabase : postgresql://user:password@host:5432/database
DATABASE_URL=mysql://user:password@host:3306/database

# Environnement
NODE_ENV=production

# URL de l'Application (remplacez par votre URL Vercel)
VITE_API_URL=https://les-batisseurs-engages.vercel.app

# OAuth GitHub (optionnel, pour la connexion sociale)
VITE_OAUTH_GITHUB_ID=your_github_oauth_id
VITE_OAUTH_GITHUB_SECRET=your_github_oauth_secret

# ============================================
# Instructions de Configuration
# ============================================
# 1. Créez un compte TiDB Cloud gratuit : https://tidbcloud.com/free-tier
# 2. Créez un cluster Serverless (gratuit)
# 3. Récupérez la chaîne de connexion et collez-la dans DATABASE_URL
# 4. Remplacez VITE_API_URL par votre URL Vercel
# 5. Ajoutez ces variables dans Vercel Settings → Environment Variables
# 6. Redéployez votre application

# ============================================
# Coûts
# ============================================
# Vercel : 0€/mois (gratuit)
# TiDB Cloud : 0€/mois (5 Go gratuit)
# Total : 0€/mois ✅
